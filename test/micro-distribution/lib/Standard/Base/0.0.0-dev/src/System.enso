import project.Nothing.Nothing

create_process command arguments input redirect_in redirect_out redirect_err cwd=Nothing env=Nothing =
    create_process_impl command arguments input redirect_in redirect_out redirect_err cwd env

private create_process_impl command arguments input redirect_in redirect_out redirect_err cwd env = @Builtin_Method "System.create_process"

type System_Process_Result
    Result exit_code stdout stderr

exit code = @Builtin_Method "System.exit"

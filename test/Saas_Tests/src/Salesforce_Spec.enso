    c8 = ['Expected Revenue', [1000, 50, 500, Nothing]]
    c9 = ['Probability (%)', [100, 10, 10, 20]]
    c10 = ['Age', [3, 72, 72, 3]]
    c11 = ['Close Date', [Date.new 2026 1 17, Date.new 2026 1 21, Date.new 2026 1 31, Date.new 2026 3 29]]
    c12 = ['Created Date', [Date.new 2026 1 14, Date.new 2026 1 14, Date.new 2026 1 14, Date.new 2026 3 24]]

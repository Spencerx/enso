add_specs suite_builder =
    suite_builder.group "Salesforce" group_builder->
        group_builder.specify "raw_table_data_to_table converts mixed Salesforce report cells" <|
            raw_column_data = raw_column_data_input_1.parse_json
            raw_table_data = raw_table_data_input_1.parse_json
            Salesforce.raw_table_data_to_table raw_column_data raw_table_data . should_equal expected_table_input_1

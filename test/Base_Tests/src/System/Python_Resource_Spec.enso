from Standard.Base import all
from Standard.Test import all

from project.Utils import create_tmp_dir, enso_run, create_new_project

polyglot java import java.lang.StringBuilder as J_StringBuilder

## Note that both tests runs with `--jvm`, as there is no Python inside
   Native image.

add_specs suite_builder = suite_builder.group "Python resources" group_builder->

    # If no Python code is executed, there should be no Python logs
    group_builder.specify "Python classes are not loaded if unnecessary" <|
        with_project "Proj" "main = 1" \proj_dir ->
            args = ["--jvm", "--run", proj_dir.path] + sys_props
            out = enso_run args
            has_python_logs = out.lines.any (is_log_from_python _)
            clue = with_string_builder \sb ->
                sb.append "There should be no Python logs in the output. "
                sb.append "Output from subprocess: "
                sb.append out.to_text
            Test.with_clue clue <|
                has_python_logs.should_be_false

    # Python code is executed. Python context should be initialized and it
    # should be able to resolve its language home from the extracted directory.
    # Note that the extracted directory is somewhere inside our `built-distribution`,
    # instead of some location chosen by GraalPython.
    group_builder.specify "Python lang home is resolved from extracted directory" <|
        code = """
            foreign python py_func = """
                return 1 + 1
            main = py_func
        with_project "Proj" code \proj_dir ->
            args = ["--jvm", "--run", proj_dir.path] + sys_props
            out = enso_run args
            lines = out.lines
            has_python_logs = lines.any (is_log_from_python _)
            has_python_logs.should_be_true
            lang_homes = lines.fold_with_index [] \acc idx line ->
                prev_line = if idx > 0 then lines.at (idx - 1) else Nothing
                lang_home = parse_lang_home_log prev_line line
                case lang_home of
                    Nothing -> acc
                    _ -> acc + [lang_home]

            clue_1 = with_string_builder \sb ->
                sb.append "Just two language home should be reported by Python3Core. "
                sb.append "Instead got: "
                sb.append lang_homes.to_text
                sb.append " : "
            Test.with_clue clue_1 <|
                lang_homes.length . should_equal 2

            initial_home = lang_homes.at 0
            clue_2 = with_string_builder \sb ->
                sb.append "First reported Python language home should be null. "
                sb.append "Instead got: "
                sb.append initial_home.to_text
                sb.append " : "
            Test.with_clue clue_2 <|
                initial_home . contains "null" . should_be_true

            updated_home = lang_homes.at 1
            clue_3 = with_string_builder \sb ->
                sb.append "Second reported Python language home should be in the extracted directory. "
                sb.append "Instead got: "
                sb.append "'"
                sb.append updated_home.to_text
                sb.append "'. "
                sb.append "The entire output is:  "
                lines.each \line ->
                    sb.append line
                    sb.append "\n"
                sb.append " : "
            Test.with_clue clue_3 <|
                updated_home.contains "built-distribution" . should_be_true


## Python3Core logs the resolved language home location in subsequent line.
private parse_lang_home_log prev_line:(Text|Nothing) line:Text -> (Text | Nothing) =
    if prev_line == Nothing then Nothing else
        case (prev_line.contains "Python3Core" && line.contains "Language home") of
            False -> Nothing
            True ->
                lang_home = line.split "Language home:" . at 1 . trim
                lang_home


## Runs an action with newly created Project in a temporary directory.
private with_project proj_name:Text main_src:Text action:(Function File Nothing) =
    tmp_root = create_tmp_dir

    cleanup =
        tmp_root.delete recursive=True

    Panic.with_finalizer cleanup <|
        proj_dir = create_new_project tmp_root proj_name main_src
        action proj_dir


private is_log_from_python log:Text -> Boolean =
    log.contains "Python3Core" || log.contains "PythonLanguage" || log.contains "PythonContext"


## Sys props that enable some Python loggers
private sys_props =
    logger_names = Vector.build \bldr ->
       bldr.append "python.com.oracle.graal.python.builtins.Python3Core"
       bldr.append "python.com.oracle.graal.python.PythonLanguage"
       bldr.append "python.com.oracle.graal.python.runtime.PythonContext"
    args = logger_names.map \name ->
        args_for_logger = Vector.build \bldr ->
            bldr.append "--vm.D"
            bldr.append <| "polyglot.log." + name + ".level" + "=" + "FINE"
            bldr.append "--vm.D"
            bldr.append <| name + ".Logger.level=trace"
        args_for_logger
    args.flatten


private with_string_builder (func : Function J_StringBuilder J_StringBuilder) -> Text =
    sb = J_StringBuilder.new
    new_sb = func sb
    new_sb.toString


main filter=Nothing =
    suite = Test.build suite_builder->
        add_specs suite_builder
    suite.run_with_filter filter

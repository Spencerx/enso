from Standard.Base import all
from Standard.Test import all

polyglot java import java.lang.ProcessBuilder as J_ProcessBuilder
polyglot java import java.lang.Process as J_Process
polyglot java import java.lang.System as J_System
polyglot java import java.lang.String as J_String
polyglot java import java.io.File as J_File
polyglot java import org.enso.base_test_helpers.ExecutableLocation as J_ExecutableLocation


add_specs suite_builder = suite_builder.group "Engine runner" group_builder->
    group_builder.specify "should be able to run a project specified with relative path" <|
        tmp_root = tmp_dir

        cleanup =
            tmp_root.delete recursive=True

        Panic.with_finalizer cleanup <|
            proj_parent_dir = tmp_root / "Dir1" / "Dir2"
            proj_parent_dir.create_directory
            proj_dir = create_dummy_project proj_parent_dir "Proj" "main = 42"
            proj_dir.exists . should_be_true
            proj_dir.is_directory . should_be_true
            # The spawned subprocess will try to run the newly created project
            # via a relative path
            args = [enso_bin, "--run", "Dir1/Dir2/Proj"]
            proc_bldr = J_ProcessBuilder.new args
            proc_bldr.redirectErrorStream True
            proc_bldr.directory (J_File.new tmp_root.path)
            proc = proc_bldr.start
            retcode = proc.waitFor
            bytes = proc.getInputStream.readAllBytes
            out = J_String.new bytes
            clue = "Output from subprocess: " + out.to_text
            Test.with_clue clue <|
                retcode . should_equal 0


runs_in_aot =
    prop = J_System.getProperty "org.graalvm.nativeimage.imagecode"
    prop == "runtime"


tmp_dir -> File =
    tmp_file = File.create_temporary_file
    tmp_path = tmp_file.path
    tmp_file.delete
    d = File.new tmp_path
    d.create_directory
    d

enso_bin -> Text =
    J_ExecutableLocation.getExecutableLocation

create_dummy_project parent_dir:File proj_name:Text main_src:Text -> File =
    Runtime.assert parent_dir.exists
    Runtime.assert parent_dir.is_directory
    proj_dir = parent_dir / proj_name
    args = ["--new", proj_dir.path, "--new-project-name", proj_name]
    ret = Process.run enso_bin args
    ret.exit_code . should_equal Exit_Code.Success
    main = proj_dir / "src" / "Main.enso"
    Runtime.assert main.exists
    main_src.write main
    proj_dir


main filter=Nothing =
    suite = Test.build suite_builder->
        add_specs suite_builder
    suite.run_with_filter filter

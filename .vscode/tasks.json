{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cargo",
			"command": "build",
			"args": ["-p", "enso-build-ci-gen"],
			"problemMatcher": [
				"$rustc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"label": "Rust Gen CI"
		},
		{
			"type": "cargo",
			"command": "build",
			"args": ["--profile", "buildscript", "-p", "enso-build-cli"],
			"problemMatcher": [
				"$rustc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"label": "Rust ./run"
		}
	]
}
{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Enso GUI",
      "type": "npm",
      "script": "dev:gui",
      "isBackground": true,
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": { "reveal": "silent" },
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".",
              "file": 1,
              "line": 1,
              "column": 1,
              "message": 1
            }
          ],
          "background": {
            "activeOnStart": false,
            "beginsPattern": { "regexp": ".*Local:.*http.*localhost.*5173.*" },
            "endsPattern": { "regexp": "." }
          }
        }
      ]
    }
  ]
}

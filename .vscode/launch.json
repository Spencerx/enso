{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java+",
      "request": "launch",
      "name": "Launch Enso File"
    },
    {
      "name": "Listen to 5005",
      "type": "java+",
      "request": "attach",
      "listen": "true",
      "hostName": "localhost",
      "port": "5005"
    },
    {
      "name": "Debug Adapter Protocol",
      "type": "node",
      "debugServer": 4711,
      "request": "attach"
    },
    {
      "type": "nativeimage",
      "request": "launch",
      "name": "Launch Native Image",
      "nativeImagePath": "${workspaceFolder}/enso",
      "windows": {
        "nativeImagePath": "${workspaceFolder}/built-distribution/enso-engine-0.0.0-dev-windows-amd64/enso-0.0.0-dev/bin/enso.exe"
      },
      "args": "--run ${file}"
      // - Specify `polyglot.dap` property
      // - Launch Native Image normally and then
      // - Connect via Debug Adapter Protocol
      // "args": "--vm.D=polyglot.dap=4711 --run ${file}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Rust Gen CI",
      "cargo": ["run", "-p", "enso-build-ci-gen"],
    },
   {
      "type": "lldb",
      "request": "launch",
      "name": "Rust ./run",
      "cargo": ["run", "-p", "enso-build-ci"],
    },
  ]
}
from Standard.Base import all
from Standard.Base.Metadata.Choice import Option
from Standard.Base.Metadata.Widget import Single_Choice

import project.Identifier.Identifier
import project.Snowflake_Connection.Snowflake_Connection

type Snowflake_File_Format
    NONE

    Saved name:Identifier=(Missing_Argument.throw "name")

    CSV delimiter:Text="," parse_header:Auto_Boolean=..TRUE date_format:Text="" time_format:Text="" timestamp_format:Text="" compression:Compression=..AUTO

    JSON date_format:Text="" time_format:Text="" timestamp_format:Text="" compression:Compression=..AUTO

    AVRO

    ORC

    PARQUET

    XML

    ## Create a file format directly from a SQL string.
    Custom sql:Text=(Missing_Argument.throw "sql")

    ## ---
       private: true
       ---
    private to_sql self = case self of
        Snowflake_File_Format.NONE -> ''
        Snowflake_File_Format.Saved identifier -> 'FILE_FORMAT = ' + identifier.to_identifier
        Snowflake_File_Format.CSV delimiter parse_header dt tm ts compression ->
            output = 'TYPE = CSV'
                + " FIELD_DELIMITER = '" + (delimiter.replace "'" "''") + "'"
                + (if parse_header == Auto_Boolean.FALSE then "" else " PARSE_HEADER = "+parse_header.to_sql)
                + (if dt != "" then " DATE_FORMAT = '" + (dt.replace "'" "''") + "'"  else ' DATE_FORMAT = AUTO')
                + (if tm != "" then " TIME_FORMAT = '" + (tm.replace "'" "''") + "'"  else ' TIME_FORMAT = AUTO')
                + (if ts != "" then " TIMESTAMP_FORMAT = '" + (ts.replace "'" "''") + "'"  else ' TIMESTAMP_FORMAT = AUTO')
                + (if compression != Auto_Boolean.AUTO then ' COMPRESSION = ' + compression.to_sql else '')
            output
        Snowflake_File_Format.JSON dt tm ts compression ->
            output = 'TYPE = JSON'
                + (if dt != "" then " DATE_FORMAT = '" + (dt.replace "'" "''") + "'"  else ' DATE_FORMAT = AUTO')
                + (if tm != "" then " TIME_FORMAT = '" + (tm.replace "'" "''") + "'"  else ' TIME_FORMAT = AUTO')
                + (if ts != "" then " TIMESTAMP_FORMAT = '" + (ts.replace "'" "''") + "'"  else ' TIMESTAMP_FORMAT = AUTO')
                + (if compression != Auto_Boolean.AUTO then ' COMPRESSION = ' + compression.to_sql else '')
            output
        Snowflake_File_Format.AVRO -> 'TYPE = AVRO'
        Snowflake_File_Format.ORC -> 'TYPE = ORC'
        Snowflake_File_Format.PARQUET -> 'TYPE = PARQUET'
        Snowflake_File_Format.XML -> 'TYPE = XML'
        Snowflake_File_Format.Custom sql -> sql

    ## ---
       private: true
       ---
       Make a selector for a file format
    private make_format_chooser connection:Snowflake_Connection =
        map_ident identifier =
            opt = identifier.to_option
            Option opt.label ("(..Saved " + opt.value + ")")
        identifiers = [Option "<Default>" "..NONE"]
            + connection.file_format_names.map map_ident
            + [Option "<CSV>" "..CSV", Option "<JSON>" "..JSON", Option "<AVRO>" "..AVRO", Option "<ORC>" "..ORC", Option "<PARQUET>" "..PARQUET", Option "<XML>" "..XML"]
        Single_Choice display=..Always values=identifiers

Snowflake_File_Format.from (that:Identifier) =
    Snowflake_File_Format.Saved that

type Auto_Boolean
    AUTO

    TRUE

    FALSE

    ## ---
       private: true
       ---
    private to_sql self = case self of
        Auto_Boolean.AUTO -> 'AUTO'
        Auto_Boolean.TRUE -> 'TRUE'
        Auto_Boolean.FALSE -> 'FALSE'

Auto_Boolean.from (that:Boolean) =
    if that then Auto_Boolean.TRUE else Auto_Boolean.FALSE

Auto_Boolean.from (that:Nothing) =
    _ = that
    Auto_Boolean.AUTO

## Specified the compression type for the file format.
type Compression
    AUTO

    GZIP

    BZ2

    BROTLI

    ZSTD

    DEFLATE

    RAW_DEFLATE

    NONE

    ## ---
       private: true
       ---
    private to_sql self = case self of
        Compression.AUTO -> 'AUTO'
        Compression.GZIP -> 'GZIP'
        Compression.BZ2 -> 'BZ2'
        Compression.BROTLI -> 'BROTLI'
        Compression.ZSTD -> 'ZSTD'
        Compression.DEFLATE -> 'DEFLATE'
        Compression.RAW_DEFLATE -> 'RAW_DEFLATE'
        Compression.NONE -> 'NONE'

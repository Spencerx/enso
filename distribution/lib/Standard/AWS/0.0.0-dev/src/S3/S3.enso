from Standard.Base import all
import Standard.Base.Enso_Cloud.Data_Link_Helpers
import Standard.Base.Metadata.Widget.Text_Input
import Standard.Base.Network.HTTP.Response_Body.Response_Body
import Standard.Base.Runtime.Context
import Standard.Base.System.File.Generic.File_Like.File_Like
import Standard.Base.System.File_Format_Metadata.File_Format_Metadata
import Standard.Base.System.Input_Stream.Input_Stream
from Standard.Base.Network.HTTP.Response import filename_from_content_disposition

import project.AWS_Credential.AWS_Credential
import project.Errors.AWS_SDK_Error
import project.Errors.More_Records_Available
import project.Errors.S3_Error
import project.S3.S3_File.S3_File

polyglot java import java.io.IOException
polyglot java import org.enso.aws.S3ClientWrapper

## ---
   icon: data_input
   ---
   Gets the list of the S3 bucket names.

   ## Arguments
    - `credentials`: The credentials to use to access S3. If not specified, the
      default credentials are used.

   ## Returns
    - A vector of bucket names (as Text).

   ## Errors
    - If the credentials are invalid or access to S3 is denied, then an
      `AWS_SDK_Error` will be raised.
@credentials AWS_Credential.default_widget
list_buckets credentials:AWS_Credential=..Default -> Vector Text ! S3_Error =
    client = _make_client credentials

    buckets = client.listBuckets
    Error.return_if_error buckets

    Vector.from_polyglot_array buckets

## ---
   icon: data_input
   ---
   Gets the list of the items inside a bucket.

   ## Arguments
    - `bucket`: the name of the bucket.
    - `prefix`: the prefix of keys to match.
    - `max_count`: the maximum number of items to return. The default is 1000.
    - `credentials`: The credentials to use to access the S3 bucket. If not
      specified, the default credentials are used.

   ## Returns
    - A vector of object keys (as Text) (including the prefix).

   ## Errors
    - If the credentials are invalid or access to S3 is denied, then an
      `AWS_SDK_Error` will be raised.
    - If the bucket does not exist, an `S3_Bucket_Not_Found` error is thrown.
    - If more items are available than the `max_count` parameter, a
      `More_Records_Available` warning is attached to the result.
@bucket (Text_Input display=..Always)
@credentials AWS_Credential.default_widget
list_objects (bucket : Text = Missing_Argument.throw "bucket") prefix:Text="" credentials:AWS_Credential=..Default max_count:Integer=1000 -> Vector S3_File ! S3_Error =
    names = read_bucket bucket prefix credentials delimiter="" max_count=max_count . second
    names.map name-> S3_File.new "s3://"+bucket+"/"+name credentials

## ---
   private: true
   advanced: true
   icon: data_input
   ---
   Gets the versions of an object from an S3 bucket.

   ## Arguments
    - `bucket`: the name of the bucket.
    - `key`: the key of the object.
    - `credentials`: AWS credentials. If not provided, the default credentials
      will be used.
@bucket (Text_Input display=..Always)
@key (Text_Input display=..Always)
@credentials AWS_Credential.default_widget
list_object_versions (bucket : Text = Missing_Argument.throw "bucket") (key : Text = Missing_Argument.throw "key") credentials:AWS_Credential=..Default -> Vector Text =
    client = _make_client_for_bucket bucket credentials

    response = client.listObjectVersions bucket key
    Error.return_if_error response

    Vector.from_polyglot_array response

## ---
   private: true
   advanced: true
   icon: data_input
   ---
   Gets an object from an S3 bucket. Returns a raw stream which can be read once.

   ## Arguments
    - `bucket`: the name of the bucket.
    - `key`: the key of the object.
    - `version_id`: the version of the object to get. If `Nothing` or an empty
       string is provided, the latest version will be fetched.
    - `credentials`: AWS credentials. If not provided, the default credentials
      will be used.
@bucket (Text_Input display=..Always)
@key (Text_Input display=..Always)
@credentials AWS_Credential.default_widget
get_object (bucket : Text = Missing_Argument.throw "bucket") (key : Text = Missing_Argument.throw "key") version_id:Text="" credentials:AWS_Credential=..Default -> Response_Body ! S3_Error =
    client = _make_client_for_bucket bucket credentials
    response = client.getObject bucket key version_id
    _wrap_response bucket key response

## ---
   private: true
   advanced: true
   icon: metadata
   ---
   Creates a presigned URL for an object in an S3 bucket. This URL can be used to
   access the object without requiring AWS credentials, but it will only be valid
   for a limited time.

   ## Arguments
    - `bucket`: the name of the bucket.
    - `key`: the key of the object.
    - `version_id`: the version of the object to get. If `Nothing` or an empty
       string is provided, the latest version will be fetched.
    - `duration`: the duration for which the presigned URL will be valid. The
      default is 1 minute.
    - `credentials`: AWS credentials. If not provided, the default credentials
      will be used.
@bucket (Text_Input display=..Always)
@key (Text_Input display=..Always)
@duration Duration.default_widget
@credentials AWS_Credential.default_widget
presigned_url (bucket : Text = Missing_Argument.throw "bucket") (key : Text = Missing_Argument.throw "key") version_id:Text="" duration:Duration=(Duration.of_minutes 1) credentials:AWS_Credential=..Default -> URI ! S3_Error =
    client = _make_client_for_bucket bucket credentials
    seconds = duration.total_seconds.floor
    presigned = client.signedUri bucket key version_id seconds
    Error.return_if_error presigned
    URI.parse presigned

## ---
   advanced: true
   icon: data_input
   ---
   Gets the metadata of a bucket or object.

   ## Arguments
    - `bucket`: the name of the bucket.
    - `key`: the prefix of keys to match.
    - `credentials`: The credentials to use to access the S3 bucket. If not
      specified, the default credentials are used.

   ## Returns
    - A Dictionary of the associated metadata of a bucket or object.

   ## Errors
    - If the credentials are invalid or access to S3 is denied, then an
      `AWS_SDK_Error` will be raised.
    - If the bucket does not exist, an `S3_Bucket_Not_Found` error is thrown.
    - If the object does not exist, an `S3_Key_Not_Found` error is thrown.
@bucket (Text_Input display=..Always)
@credentials AWS_Credential.default_widget
head (bucket : Text = Missing_Argument.throw "bucket") key:Text="" credentials:AWS_Credential=..Default -> Dictionary Text Any ! S3_Error =
    response = raw_head bucket key "" credentials
    pairs = response.sdkFields.map f-> [f.memberName, f.getValueOrDefault response]
    Dictionary.from_vector pairs

## ---
   advanced: true
   icon: data_output
   ---
   Puts an object or text onto S3. Returns the metadata of the uploaded object.

   ## Arguments
    - `bucket`: the name of the bucket.
    - `key`: the key of the object.
    - `credentials`: AWS credentials. If not provided, the default credentials
      will be used.
    - `body`: the content to upload, either as a File or as Text. If an S3_File is provided then will use the
       copy_object. This allows for copying objects within S3 without downloading them first, which is more efficient.
@bucket (Text_Input display=..Always)
@key (Text_Input display=..Always)
@credentials AWS_Credential.default_widget
put_object (bucket : Text = Missing_Argument.throw "bucket") (key : Text = Missing_Argument.throw "key") (body:(S3_File | File_Like | Text) = Missing_Argument.throw "body") credentials:AWS_Credential=..Default -> S3_File =
    Context.Output.if_enabled disabled_message="As writing is disabled, cannot write to S3. Press the Write button ▶ to perform the operation." panic=False (_->Nothing)
    result = if body.is_a S3_File then S3.copy_object bucket key body.bucket body.key credentials else
        client = _make_client_for_bucket bucket credentials
        if body.is_a Text then client.putObjectFromText bucket key body else
            Data_Link_Helpers.as_file body file->
                client.putObjectFromFile bucket key file.path
    Error.return_if_error result
    S3_File.new "s3://"+bucket+"/"+key credentials

## ---
   private: true
   ---
   Deletes the object. It will not raise any errors if the object does not exist.
delete_object (bucket : Text = Missing_Argument.throw "bucket") (key : Text = Missing_Argument.throw "key") credentials:AWS_Credential=..Default =
    Context.Output.if_enabled disabled_message="As writing is disabled, cannot delete from S3. Press the Write button ▶ to perform the operation." panic=False (_->Nothing)
    client = _make_client_for_bucket bucket credentials
    client.deleteObject bucket key . if_not_error Nothing

## ---
   private: true
   ---
copy_object (source_bucket : Text) (source_key : Text) (target_bucket : Text) (target_key : Text) credentials:AWS_Credential=..Default =
    Context.Output.if_enabled disabled_message="As writing is disabled, cannot copy to S3. Press the Write button ▶ to perform the operation." panic=False (_->Nothing)
    client = _make_client_for_bucket source_bucket credentials
    client.copyObject target_bucket target_key source_bucket source_key . if_not_error Nothing

## ---
   private: true
   ---
   Gets the raw metadata of a bucket or object.

   ## Arguments
    - `bucket`: the name of the bucket.
    - `key`: the key of the object.
    - `version_id`: the version of the object to get. If `Nothing` or an empty
       string is provided, the latest version will be fetched.
    - `credentials`: AWS credentials.
private raw_head bucket:Text key:Text version_id:Text credentials:AWS_Credential -> Any ! S3_Error =
    client = _make_client_for_bucket bucket credentials
    if key == "" then client.headBucket bucket else
        client.headObject bucket key version_id

## ---
   private: true
   ---
   Reads an S3 bucket returning a pair of vectors, one with common prefixes and
   one with object keys.

   ## Arguments
    - `bucket`: The name of the bucket.
    - `prefix`: The prefix to use when searching for keys to return.
    - `credentials`: The credentials for the AWS resource.
    - `delimiter`: The delimiter used to deduce common prefixes.
read_bucket bucket:Text prefix:Text="" credentials:AWS_Credential=..Default delimiter:Text="/" max_count:Integer=1000 -> Pair Vector Vector ! S3_Error =
    client = _make_client_for_bucket bucket credentials

    result = client.readBucket bucket prefix delimiter max_count
    Error.return_if_error result

    pair = Pair.new result.prefixes result.keys
    if result.finished then pair else Warning.attach (More_Records_Available.Warning "Not all keys returned. Additional objects found.") pair

## ---
   private: true
   ---
   Makes a client for the default region.
private _make_client credentials:AWS_Credential -> S3ClientWrapper =
    region = credentials.get_default_region.as_java
    S3ClientWrapper.forCredential credentials.as_java region

## ---
   private: true
   ---
   Makes a client using the region in which the specified bucket is located. This
   is necessary, because if we are fetching the wrong region, we will get
   `PermanentRedirect` errors.
private _make_client_for_bucket bucket_name:Text credentials:AWS_Credential -> S3ClientWrapper =
    java_credential = credentials.as_java
    S3ClientWrapper.forBucket java_credential bucket_name credentials.get_default_region.as_java

private _wrap_response bucket key response =
    s3_uri = URI.parse (uri_prefix + bucket + "/") / key
    inner_response = response.response
    content_type = inner_response.contentType
    name = filename_from_content_disposition inner_response.contentDisposition . if_nothing <|
        key.split "/" . last
    metadata = File_Format_Metadata.Value path=key name=name content_type=content_type

    handler ~action = Panic.catch IOException action caught_panic->
        Error.throw (S3_Error.Error ("An IO error has occurred: " + caught_panic.payload.to_text) s3_uri.to_text)

    input_stream = Input_Stream.new response handler
    Response_Body.Raw_Stream input_stream metadata s3_uri

## ---
   private: true
   ---
scheme = "s3"

## ---
   private: true
   ---
uri_prefix = scheme + "://"

from Standard.Base import all

import project.Table.Table

## PRIVATE
   Constructor to be used by implementations of the Table type to be able to provide a conversion.
table_from_implementation value implementation =
    Table.Value value implementation

## PRIVATE
   Extracts the underlying value from a generic Table - e.g. In_Memory_Table or DB_Table.
   It should only be used by implementations to access their implementation details.
get_underlying_from_table value:Table = value.underlying

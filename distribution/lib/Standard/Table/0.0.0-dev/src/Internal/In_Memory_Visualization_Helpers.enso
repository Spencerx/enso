private

from Standard.Base import all

import project.Column.Column
import project.In_Memory_Column.In_Memory_Column
import project.Value_Type.Value_Type

polyglot java import org.enso.table.data.column.operation.CountNonTrivialWhitespace
polyglot java import org.enso.table.data.column.operation.CountUntrimmed
polyglot java import org.enso.table.data.column.operation.RequiresNumberFormatting
polyglot java import org.enso.table.data.column.operation.DistinctValuesCheck

type In_Memory_Visualization_Helpers
    ## PRIVATE
       Counts the number of text values with leading or trailing whitespace.
       Used for data quality indicator in Table Viz.
    count_untrimmed this_column sample_size:Integer -> Integer | Nothing =
        if (_can_contain_text (this_column:Column).value_type).not then Nothing else
            CountUntrimmed.apply (this_column:In_Memory_Column).java_column sample_size

    ## PRIVATE
       Indicates if a numeric column requires formatting in table viz
    requires_numeric_formatter_check this_column -> Boolean =
        if ((this_column:Column).value_type.is_numeric).not then False else
            RequiresNumberFormatting.apply (this_column:In_Memory_Column).java_column

    ## PRIVATE
       Counts the number of text values with non trivial whitespace.
       Used for data quality indicator in Table Viz.
    count_non_trivial_whitespace this_column sample_size:Integer -> Integer | Nothing =
        if (_can_contain_text (this_column:Column).value_type).not then Nothing else
            CountNonTrivialWhitespace.apply (this_column:In_Memory_Column).java_column sample_size
    
    ## PRIVATE
       Counts the number of distinct values
       Used for determining which filters should be used
    check_distinct_values this_column -> Boolean =
        if (_can_contain_text (this_column:Column).value_type).not then False else
            DistinctValuesCheck.apply (this_column:In_Memory_Column).java_column

## PRIVATE
   Determines if a value type is eligable for a text data quality count
private _can_contain_text value_type:Value_Type -> Boolean =
    value_type == Value_Type.Mixed || value_type.is_text

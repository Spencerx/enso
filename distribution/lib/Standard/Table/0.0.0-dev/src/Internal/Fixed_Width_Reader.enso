from Standard.Base import all
import Standard.Base.Errors.Encoding_Error.Encoding_Error
import Standard.Base.Errors.File_Error.File_Error
import Standard.Base.Errors.Illegal_Argument.Illegal_Argument
import Standard.Base.System.Input_Stream.Input_Stream

import project.Fixed_Width.Fixed_Width_Format.Fixed_Width_Format
import project.Fixed_Width.Fixed_Width_Format.Fixed_Width_Layout
import project.Fixed_Width.Fixed_Width_Format.Infer_Layout
import project.Fixed_Width.Invalid_Fixed_Width_Rows.Invalid_Fixed_Width_Rows
import project.Fixed_Width.On_Empty_Field.On_Empty_Field
import project.Internal.Java_Problems
from project.Errors import Empty_File_Error, Fixed_Width_Line_Too_Long, No_Column_Names_Found
from project.In_Memory_Table import from_java_table

polyglot java import java.io.IOException
polyglot java import java.io.Reader
polyglot java import org.enso.table.parsing.IdentityParser
polyglot java import org.enso.table.parsing.TypeInferringParser
polyglot java import org.enso.table.read.FixedWidthDecodingProblemAggregator
polyglot java import org.enso.table.read.FixedWidthReader
polyglot java import org.enso.table.read.FixedWidthReader.FixedWidthLayoutEntry
polyglot java import org.enso.table.read.FixedWidthReader.InvalidFixedWidthRowsBehavior

## PRIVATE
   Reads a fixed-width column file according to the provided format.

   Arguments:
   - format: The specification of format of the file, including the column
     layout.
   - file: The file to read.
   - on_problems: Specifies the behavior when a problem occurs during the
     operation. By default, a warning is issued, but the operation proceeds.
     If set to `Report_Error`, the operation fails with a dataflow error.
     If set to `Ignore`, the operation proceeds without errors or warnings.
read_file : Fixed_Width_Format -> File -> Problem_Behavior -> Any
read_file format file on_problems:Problem_Behavior =
    file.with_input_stream [File_Access.Read] stream->
        read_stream format stream on_problems related_file=file

## PRIVATE
   Reads fixed-width column data from an input stream according to the provided
   format.

   Arguments:
   - format: The specification of format of the file, including the column
     layout.
   - stream: An `Input_Stream` to be used as the data source.
   - on_problems: Specifies the behavior when a problem occurs during the
     operation. By default, a warning is issued, but the operation proceeds.
     If set to `Report_Error`, the operation fails with a dataflow error.
     If set to `Ignore`, the operation proceeds without errors or warnings.
   - related_file: The file related to the provided `java_stream`, if available,
     or `Nothing`. It is used for more detailed error reporting.
read_stream : Fixed_Width_Format -> Input_Stream -> Problem_Behavior -> File | Nothing -> Any
read_stream format input_stream on_problems:Problem_Behavior related_file=Nothing =
    # We always ensure the stream is peekable, as that also implies buffering which is supposedly more efficient e.g. when working with files.
    handle_io_exception related_file <|
        buffered_input_stream = input_stream.as_peekable_stream
        decoding_problem_aggregator = FixedWidthDecodingProblemAggregator.new
        result = buffered_input_stream.with_java_stream java_stream->
            Illegal_Argument.handle_java_exception <| Empty_File_Error.handle_java_exception <| No_Column_Names_Found.handle_java_exception <| Fixed_Width_Line_Too_Long.handle_java_exception <|
                Java_Problems.with_problem_aggregator on_problems java_problem_aggregator->
                    reader = prepare_reader format format.encoding on_problems decoding_problem_aggregator java_problem_aggregator
                    java_table = reader.read java_stream
                    from_java_table java_table
        problems = Vector.from_polyglot_array decoding_problem_aggregator.summarize . map decoding_problem->
            Encoding_Error.Error decoding_problem.message
        on_problems.attach_problems_after result problems

## Prepare a FixedWidthReader for reading.
private prepare_reader format:Fixed_Width_Format effective_encoding:Encoding on_problems:Problem_Behavior decoding_problem_aggregator java_problem_aggregator =
    warnings_as_errors = on_problems == Problem_Behavior.Report_Error
    row_limit = format.row_limit.rows_to_read.if_nothing -1
    skip_rows = format.skip_rows
    on_invalid_rows_java = case format.on_invalid_rows of
        Invalid_Fixed_Width_Rows.Keep_Invalid_Rows -> InvalidFixedWidthRowsBehavior.KEEP
        Invalid_Fixed_Width_Rows.Drop_Invalid_Rows -> InvalidFixedWidthRowsBehavior.DROP
    empty_to_null = format.on_empty_field == On_Empty_Field.As_Nothing
    value_parser = if format.value_formatter.is_nothing then IdentityParser.new else
        wrapped = format.value_formatter.wrap_base_parser IdentityParser.new
        TypeInferringParser.new format.value_formatter.get_specific_type_parsers wrapped

    # Pass either the layout, or the inference enum.
    case format.layout of
        infer : Infer_Layout ->
            FixedWidthReader.new Nothing infer.to_java effective_encoding.to_java_charset skip_rows row_limit on_invalid_rows_java empty_to_null value_parser warnings_as_errors decoding_problem_aggregator java_problem_aggregator
        layout : Fixed_Width_Layout ->
            FixedWidthReader.new (format_to_java layout) Nothing effective_encoding.to_java_charset skip_rows row_limit on_invalid_rows_java empty_to_null value_parser warnings_as_errors decoding_problem_aggregator java_problem_aggregator

private format_to_java layout =
    layout.entries.map e->
        FixedWidthLayoutEntry.new e.start e.width e.name

## PRIVATE
private handle_io_exception related_file ~action = Panic.catch IOException action cause->
    File_Error.wrap_io_exception related_file cause.payload

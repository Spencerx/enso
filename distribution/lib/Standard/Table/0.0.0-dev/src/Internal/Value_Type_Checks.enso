from Standard.Base import all

import project.Value_Type.Value_Type
import project.Internal.Value_Type_Helpers
from project.Errors import Invalid_Value_Type

## Checks that both arguments can be compared for ordering.
   Reports an `Invalid_Value_Type` error if not.
are_comparable arg1:Any arg2:Any -> Nothing ! Invalid_Value_Type =
    type_1 = Value_Type_Helpers.find_argument_type arg1
    if type_1.has_ordering.not then Error.throw (Invalid_Value_Type.Not_Ordered type_1)

    type_2 = Value_Type_Helpers.find_argument_type arg2
    if type_2.is_nothing.not && type_2.has_ordering.not then Error.throw (Invalid_Value_Type.Not_Ordered type_2)

    if type_2.is_nothing.not && (_are_comparable type_1 type_2 . not) then Error.throw (Invalid_Value_Type.Incomparable type_1 type_2)
    Nothing

## Checks that the provided argument (either a value or a Column) is of a
   boolean type. Reports an `Invalid_Value_Type` error if not.
is_boolean argument:Any -> Nothing ! Invalid_Value_Type =
    _check_value_type argument .is_boolean Value_Type.Boolean

## Checks that the provided argument (either a value or a Column) is of a
   numeric type. Reports an `Invalid_Value_Type` error if not.
is_numeric argument:Any -> Nothing ! Invalid_Value_Type =
    _check_value_type argument .is_numeric "a numeric"

## Checks that the provided argument (either a value or a Column) is of an
   integer type. Reports an `Invalid_Value_Type` error if not.
is_integer argument:Any -> Nothing ! Invalid_Value_Type =
    _check_value_type argument .is_integer Value_Type.Integer.to_name

## Checks that the provided argument (either a value or a Column) is of a text
   type. Reports an `Invalid_Value_Type` error if not.
is_text argument:Any -> Nothing ! Invalid_Value_Type =
    _check_value_type argument .is_text Value_Type.Char.to_name

## Checks that the provided argument (either a value or a Column) is of a Date
   type. Reports an `Invalid_Value_Type` error if not.
is_date argument:Any -> Nothing ! Invalid_Value_Type =
    _check_value_type argument .is_date Value_Type.Date

## Checks if the provided argument (which may be a value or a Column) has
   type `Date` or `Date_Time`. Reports an `Invalid_Value_Type` error if not.
has_date argument:Any -> Nothing ! Invalid_Value_Type =
    _check_value_type argument .has_date "Date or Date_Time"

## Checks if the provided argument (which may be a value or a Column) has
   type `Time_Of_Day` or `Date_Time`. Reports an `Invalid_Value_Type` error if
   not.
has_time argument:Any -> Nothing ! Invalid_Value_Type =
    _check_value_type argument .has_time "Time_Of_Day or Date_Time"

## Checks that the provided argument (either a value or a Column) is of a
   `Date_Time` type. Reports an `Invalid_Value_Type` error if not.
is_date_time argument:Any -> Nothing ! Invalid_Value_Type =
    _check_value_type argument .is_date_time Value_Type.Date_Time.to_name

## Checks that the provided argument (either a value or a Column) has type `Date`,
   `Time_Of_Day` or `Date_Time`. Reports an `Invalid_Value_Type error` if not.
is_date_or_time argument:Any -> Nothing ! Invalid_Value_Type =
    _check_value_type argument .is_date_or_time "date/time"

private _check_value_type argument:Any condition:(Value_Type->Boolean) type_kind:(Text|Value_Type) -> Nothing ! Invalid_Value_Type =
    typ = Value_Type_Helpers.find_argument_type argument
    if typ!=Value_Type.Null && condition typ . not then Value_Type_Helpers.raise_unexpected_type type_kind argument
    Nothing

private _are_comparable type_1:Value_Type type_2:Value_Type -> Boolean =
    Error.return_if_error type_1
    Error.return_if_error type_2

    find_bucket typ:Value_Type =
        buckets = [["Integer", "Byte", "Float", "Decimal"], ["Char"], ["Date"], ["Date_Time"], ["Time"], ["Boolean"], ["Mixed"], ["Null"]]
        ctor_name = typ.to_name
        buckets.index_of bucket->
            bucket.contains ctor_name

    bucket_1 = find_bucket type_1
    bucket_2 = find_bucket type_2
    either_type_is_not_ordered = bucket_1.is_nothing || bucket_2.is_nothing
    if either_type_is_not_ordered then False else
        comparable_with_everything = [Value_Type.Mixed, Value_Type.Null]
        if (comparable_with_everything.contains type_1) || (comparable_with_everything.contains type_2) then True else
            if bucket_1.is_nothing || bucket_2.is_nothing then False else
                bucket_1 == bucket_2

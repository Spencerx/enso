from Standard.Base import all

type Expression_Statics
    ## Obtains the current date from the system clock in the system timezone.
    today -> Date =
        Date.today
    
    ## Obtains the current date-time from the system clock in the system timezone.
    now -> Date_Time =
        Date_Time.now

    ## Obtains the current time from the system clock in the default time-zone.
    time -> Time_Of_Day =
        Time_Of_Day.now

    ## Creates a regular expression (alternatively use r/expression/)
    regex expression = Regex.compile expression

    ## Multiples two values.
    * this that = this * that

    ## Divides this by that.
    / this that = this / that

    ## Adds two values.
    + this that = this + that

    ## Subtracts that from this.
    - this that = this - that

    ## Compares two values for equality.
    == this that = this == that

    ## Compares two values for inequality.
    != this that = this != that

    ## Compute the result of raising this to the power that.
    ^ this that = this ^ that

    ## Computes the remainder when dividing this by that.
    % this that = this % that

    ## Compares if this is less than that
    < this that = this < that

    ## Compares if this is less than or equal to that
    <= this that = this <= that

    ## Compares if this is greater than that
    > this that = this > that

    ## Compares if this is greater than or equal to that
    >= this that = this >= that

    ## The mathematical constant pi, equal to the ratio of a circle circumference
       to its diameter.
    pi -> Float = Math.pi

    ## The mathematical constant e, the base of the natural logarithm.
    e -> Float = Math.e

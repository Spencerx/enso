from Standard.Base import all
from Standard.Base.Enso_Cloud.Enso_Secret import as_credential_reference
from Standard.Base.Metadata.Choice import Option

import Standard.Base.Errors.Unimplemented.Unimplemented
import Standard.Base.Metadata.Widget

from Standard.Table import Table

polyglot java import org.enso.base.enso_cloud.ExternalLibraryCredentialHelper.CredentialReference
polyglot java import org.enso.saas.salesforce.SalesforceService

type Salesforce
    ## ---
       private: true
       ---
    private Service (salesforce_service:SalesforceService)

    ## ---
       icon: cloud
       ---
       Initializes the Salesforce instance using the given credentials file.

       ## Arguments:
        - `credentials`: a Cloud secret or a file containing Salesforce credentials.
    initialize : File | Enso_Secret -> Salesforce
    initialize credentials =
        credentials_reference = as_credential_reference credentials CredentialReference
        Salesforce.Service (SalesforceService.new credentials_reference)

    ## ---
       icon: people
       ---
       Get the Salesforce information about the authenticated user.
    get_user self =
        raw_result = _salesforce_get self "https://login.salesforce.com/services/oauth2/userinfo"
        result = raw_result.decode_as_json
        result

    ## ---
       icon: data_input
       ---
       Get a report from Salesforce by its name and return it as a table.

       ## Arguments:
       - `name`: the name of the report to retrieve.
    @name _make_report_name_widget
    get_report self name =
        raw_result = self.get_raw_report name
        if raw_result.get 'groupingsDown' . get 'groupings' . length > 0 then
            Unimplemented.throw "Row grouped reports are not supported yet."
        if raw_result.get 'groupingsAcross' . get 'groupings' . length > 0 then
            Unimplemented.throw "Column grouped reports are not supported yet."

        raw_columns = raw_result.get 'reportExtendedMetadata' . get 'detailColumnInfo'
        Salesforce.raw_table_data_to_table raw_columns (raw_result.get 'factMap' . get 'T!T')

    ## ---
       icon: table
       ---
       Converts raw Salesforce report column metadata and table data into an Enso Table.

       ## Arguments:
       - `raw_column_data`: JSON object containing column metadata including labels and data types.
       - `raw_table_data`: JSON object containing the raw row data from the Salesforce report.

       Parses the column types and converts each cell value appropriately:
       - String and picklist values use the display label
       - Numeric values (double, percent) use the raw value
       - Currency values extract the amount
       - Date and datetime values are parsed into Date objects
       - Boolean values use the raw value
    raw_table_data_to_table raw_column_data raw_table_data -> Table =
        parsed_columns_vector = raw_column_data.to_vector
        column_names = parsed_columns_vector.map c->((c.at 1).get 'label')
        column_types = parsed_columns_vector.map c->((c.at 1).get 'dataType')
        raw_data = raw_table_data.get 'rows'
        data = raw_data.map c-> c.get "dataCells" . map_with_index ix-> d-> 
            case column_types.at ix of 
                'string' -> d.get 'label'
                'picklist' -> d.get 'label'
                'double' -> d.get 'value'
                'percent' -> d.get 'value'
                'date' ->
                    v = d.get 'value' 
                    v.if_not_nothing <| v.parse_date
                'datetime' ->
                    v = d.get 'value' 
                    v.if_not_nothing <| v.parse_date_time
                'currency' ->
                    v = d.get 'value' 
                    v.if_not_nothing <| v.get 'amount'
                'boolean' -> d.get 'value'
                _ -> d.get 'label'
            
        Table.from_rows column_names data


    ## ---
       icon: data_input
       ---
       Get a report from Salesforce by its name and return it as raw JSON.

       ## Arguments:
       - `name`: the name of the report to retrieve.
    @name _make_report_name_widget
    get_raw_report self name =
        report_id = _get_report_id self name
        url = self.get_instance_url + "/services/data/v60.0/analytics/reports/" + report_id
        raw_result = _salesforce_get self url . decode_as_json
        raw_result

    ## ---
       private: true
       ---
    get_instance_url self =
        self.salesforce_service.getInstanceUrl

    ## ---
       private: true
       ---
    to_js_object : JS_Object
    to_js_object self =
        JS_Object.from_pairs [["type", "Salesforce"]]

private _salesforce_get salesforce url =
    header = Header.authorization_bearer salesforce.salesforce_service.getAccessToken.token
    HTTP.fetch url headers=[header]

private _get_raw_reports salesforce =
    url = salesforce.get_instance_url + "/services/data/v60.0/analytics/reports"
    raw_result = _salesforce_get salesforce url
    result = raw_result.decode_as_json
    result

private _get_report_id salesforce name =
    raw_reports = _get_raw_reports salesforce
    report_metadata = raw_reports.find r->((r.get 'name')==name)
    report_metadata.get 'id'

private _make_report_name_widget salesforce -> Widget =
    options = (_get_raw_reports salesforce).map r->
        name = r.get 'name'
        Option name name.pretty
    Widget.Single_Choice values=options display=..Always


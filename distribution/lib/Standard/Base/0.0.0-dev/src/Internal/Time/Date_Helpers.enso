## Constructs a new Date from a year, month, and day.

   ## Arguments
    - `year`: The year to represent.
    - `month`: The month-of-year to represent, from 1 (January) to 12 (December).
    - `day`: The day-of-month to represent, from 1 to 31. It must be valid for
      the year and month.
new_date_builtin year month day = @Builtin_Method "Date.new_builtin"

today = @Builtin_Method "Date.today"
year d = @Builtin_Method "Date.year"
month d = @Builtin_Method "Date.month"
day d = @Builtin_Method "Date.day"

## ---
   private: true
   ---
   Create an interval representing the duration between two points in time.

   Recommended to use `Duration.between` instead which provides defaults.

   ## Arguments
    - `start_inclusive`: The start datetime of the duration, included.
    - `end_exclusive`: The end datetime of the duration, excluded.
    - `timezone_aware`: Whether the duration between two given times should be
      aware of the timezone, that can be set for start or end times.
between_builtin : Date_Time -> Date_Time -> Boolean -> Duration
between_builtin start_inclusive end_exclusive timezone_aware = @Builtin_Method "Duration.between_builtin"

## ---
   private: true
   ---
   Create a duration from time units.

   Recommended to use `Duration.new` instead which provides defaults.

   ## Arguments
    - `hours`: hours
    - `minutes`: minutes
    - `seconds`: seconds
    - `milliseconds`: milliseconds
    - `nanoseconds`: nanoseconds
new_duration_builtin hours minutes seconds milliseconds nanoseconds = @Builtin_Method "Duration.new_builtin"

## ---
   private: true
   ---
ensure_duration : Any -> (Any -> Any) -> Any ! (Time_Error | Illegal_Argument)
ensure_duration object ~action =
    case object of
        _ : Duration -> action
        _ : Period -> Error.throw (Time_Error.Error "Cannot use Period as a parameter")
        x ->
            Error.throw <| Illegal_Argument.Error <|
                "Expected Duration type, got: " + (x.to Meta.Type . qualified_name)

duration_nanoseconds d = @Builtin_Method "Duration.nanoseconds"
duration_milliseconds d = @Builtin_Method "Duration.milliseconds"
duration_seconds d = @Builtin_Method "Duration.seconds"
duration_minutes d = @Builtin_Method "Duration.minutes"
duration_hours d = @Builtin_Method "Duration.hours"
total_milliseconds_builtin d = @Builtin_Method "Duration.total_milliseconds_builtin"
duration_plus d o = @Builtin_Method "Duration.plus_builtin"
duration_minus d o = @Builtin_Method "Duration.minus_builtin"


## ---
   private: true
   ---
   Obtains an instance of `Time_Zone` using an offset in hours, minutes and
   seconds from the UTC zone.

   Recommended to use `Time_Zone.new` instead which provides defaults.

   ## Arguments
    - `hours`: The timezone offset in hours from UTC, from -18 to +18.
    - `minutes`: The timezone offset in minutes from the nearest hour, from 0 to
      ±59. The sign must match that of the hours argument.
    - `seconds`: The timezone offset in seconds from the nearest minute, from 0
      to ±59. The sign must match that of the minutes argument.
tz_new_builtin hours minutes seconds = @Builtin_Method "Time_Zone.new_builtin"

## ---
   private: true
   ---
   This method parses the ID producing a `Time_Zone`.

   Recommended to use `Time_Zone.parse` instead which handles potential
   exceptions.

   ## Arguments
    - `text`: The text representing a zone identifier.
tz_parse_builtin text = @Builtin_Method "Time_Zone.parse_builtin"
tz_system = @Builtin_Method "Time_Zone.system"
tz_zone_id z = @Builtin_Method "Time_Zone.zone_id"
tz_offset z a = @Builtin_Method "Time_Zone.offset"

## ---
   private: true
   ---
   Obtains an instance of `Date_Time` from a year, month, day, hour, minute,
   second, nanosecond and timezone.

   Recommended to use `Date_Time.new` instead which handles potential exceptions.

   ## Arguments
    - `year`: The year to represent, any Integer is valid.
    - `month`: the month-of-year to represent, from 1 (January) to 12 (December)
    - `day`: the day-of-month to represent, from 1 to 31 and must be valid for
      the year and month
    - `hour`: the hour-of-day to represent, from 0 to 23
    - `minute`: the minute-of-hour to represent, from 0 to 59
    - `second`: the second-of-minute to represent, from 0 to 59
    - `nanosecond`: the nano-of-second to represent, from 0 to 999,999,999
    - `zone`: the timezone
date_time_new_builtin : Integer -> Integer -> Integer -> Integer -> Integer -> Integer -> Integer -> Time_Zone -> Date_Time
date_time_new_builtin year month day hour minute second nanosecond zone = @Builtin_Method "Date_Time.new_builtin"

unix_epoch_start = Date_Time.new 1970 zone=Time_Zone.utc
ensure_in_epoch date ~action =
    datetime = case date of
        x : Date_Time -> x
        x : Date -> x.to_date_time
    ret_value = action
    case Date_Time.enso_epoch_start <= datetime of
        True -> ret_value
        False ->
            Warning.attach (Time_Error.Error ("Date time '" + datetime.to_text + "' start before Enso epoch")) ret_value

date_time_enso_epoch_start = @Builtin_Method "Date_Time.epoch_start"
date_time_now = @Builtin_Method "Date_Time.now"
date_time_year dt = @Builtin_Method "Date_Time.year"
date_time_month dt = @Builtin_Method "Date_Time.month"
date_time_day dt = @Builtin_Method "Date_Time.day"
date_time_hour dt = @Builtin_Method "Date_Time.hour"
date_time_minute dt = @Builtin_Method "Date_Time.minute"
date_time_second dt = @Builtin_Method "Date_Time.second"
date_time_millisecond dt = @Builtin_Method "Date_Time.millisecond"
date_time_microsecond dt = @Builtin_Method "Date_Time.microsecond"
date_time_nanosecond dt include = @Builtin_Method "Date_Time.nanosecond_builtin"
date_time_zone dt = @Builtin_Method "Date_Time.zone"
date_time_date dt = @Builtin_Method "Date_Time.date"
date_time_of_day dt = @Builtin_Method "Date_Time.time_of_day"
date_time_plus dt d = @Builtin_Method "Date_Time.plus_builtin"
date_time_minus dt d = @Builtin_Method "Date_Time.minus_builtin"

## ---
   private: true
   ---
   Obtains an instance of `Time_Of_Day` from an hour, minute, second and
   nanosecond.

   Recommended to use `Time_Of_Day.new` instead which handles potential
   exceptions.

   ## Arguments
    - `hour`: The hour-of-day to represent, from 0 to 23.
    - `minute`: The minute-of-hour to represent, from 0 to 59.
    - `second`: The second-of-minute to represent, from 0 to 59.
    - `nanosecond`: The nano-of-second to represent, from 0 to 999,999,999.
time_new_builtin hour minute second nanosecond = @Builtin_Method "Time_Of_Day.new_builtin"
time_now = @Builtin_Method "Time_Of_Day.now"
time_hour t = @Builtin_Method "Time_Of_Day.hour"
time_minute t = @Builtin_Method "Time_Of_Day.minute"
time_second t = @Builtin_Method "Time_Of_Day.second"
time_millisecond t = @Builtin_Method "Time_Of_Day.millisecond"
time_microsecond t = @Builtin_Method "Time_Of_Day.microsecond"
time_nanoseconds t include = @Builtin_Method "Time_Of_Day.nanosecond_builtin"
time_to_seconds t = @Builtin_Method "Time_Of_Day.to_seconds"
time_plus t o = @Builtin_Method "Time_Of_Day.plus_builtin"
time_minus t o = @Builtin_Method "Time_Of_Day.minus_builtin"

private

import project.Data.Numbers.Integer
import project.Error.Error
import project.Runtime.Context
import project.Runtime.State

Integer.from (that:Context) = case that of
    Context.Input -> 1
    Context.Output -> 2
    Context.Dataflow_Stack_Trace -> 4
    _ -> Error.throw "Unknown context "+that.to_text


type Context_Helpers
    is_enabled c = @Builtin_Method "Context.is_enabled_builtin"
    with_context context enable ~action = @Builtin_Method "Runtime.with_context_builtin"

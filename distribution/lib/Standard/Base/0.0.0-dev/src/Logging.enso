import project.Any.Any
import project.Data.Numbers.Integer
import project.Data.Text.Text
import project.Data.Time.Duration.Duration
import project.Error.Error
import project.Errors.Illegal_Argument.Illegal_Argument
import project.Internal.Meta_Helpers
import project.Meta
import project.Nothing.Nothing
import project.Runtime.Managed_Resource.Managed_Resource
import project.Runtime.Ref.Ref
from project.Data.Boolean import False, True
from project.Data.Text.Extensions import all

polyglot java import org.enso.base.ProgressHandle
polyglot java import org.slf4j.LoggerFactory

## ---
   private: true
   ---
   Log a message.
   This function needs to be enabled by importing `Standard.Base.Logging` using
   `from Standard.Base.Logging import all`.
Any.log_message : Text -> Log_Level -> Any
Any.log_message self ~message:Text level:Log_Level=Log_Level.Info =
    typ = Meta_Helpers.type_of_value_or_type self
    type_name = Meta_Helpers.get_qualified_type_name_builtin typ
    logger = LoggerFactory.getLogger type_name
    log_impl logger message level []
    self

## Infrastructure for reporting logs and progress of computations.
   Useful for longer running actions (more than a second). A must for long
   running actions (more than ten seconds).  Start by invoking `Progress.run`,
   providing your own action to preform and report progress as your action
   advances. Nest your `Progress.run` invocations freely - the infrastructure is
   going to take care of combining the overall status of the computations
   together and will report it as a whole to a [progress displaying
   facility](https://github.com/enso-org/enso/pull/12126).
type Progress
    private Running handle label:Text max:Integer logger counter:Ref step:Integer

    ## Performs provided `action` while reporting its progress.
       The `action` is a function that takes a `Progress` handle and uses its
       methods to report progress of the computation.
       The value returned from `action` is returned from this method.

       ## Arguments
        - `label`: Overall description of the action
        - `up_to`: how _"long"_ - e.g. how many steps the action is expected to
          take. It has to be at least one or higher.
        - `action`: function performing the computation while reporting its
          `Progress`
        - `step`: how often the progress should be reported. It has to be at
          least one or higher.
    run label:Text up_to:Integer action:(Progress->Any) step:Integer=1 handle_name:Text="Progress" -> Any =
        logger = LoggerFactory.getLogger (Progress.to Meta.Type . qualified_name)
        min_step = step.max 1
        counter = Ref.new min_step
        max = up_to.max 1

        Managed_Resource.bracket (ProgressHandle.new handle_name max) _.close handle->
            progress = Progress.Running handle label max logger counter min_step
            log_impl logger "INIT {}:{}@{}" Log_Level.Finest [progress.handle, progress.label, max]
            res = action progress
            progress.close
            res

    ## Reports progress of the computation.
       Adds provided `amount` to the already accumulated work towards `up_to`
       value provided when creating this `Progress`.

       ## Arguments
        - `amount`: value to add to the progress. Must be >= 0

       ## Returns
       The self value.
    advance self amount:Integer=1 -> Progress =
        if amount <= 0 then Error.throw (Illegal_Argument.Error "Progress.advance: amount must be > 0")
        case self.step == 1 of
            True ->
                log_impl self.logger "ADVANCE {}+{}" Log_Level.Finest [self.handle, amount]
                self
            False ->
                current = self.counter.get
                case current > amount of
                    True ->
                        self.counter.put (current - amount)
                        self
                    False ->
                        log_impl self.logger "ADVANCE {}+{}" Log_Level.Finest [self.handle, self.step]
                        self.counter.put self.step
                        if amount > current then self.advance (amount - current) else self

    ## Closes the progress reporting.
       After invoking this method, the `Progress` instance is not usable
       anymore. Invoking this method multiple times has no effect.

       ## Returns
       The self value.
    close self =
        self.handle.close
        self

    ## Provides additional human readable detail of the status of the
       computation.

       ## Arguments
        - `info`: textual description of what's going on

       ## Returns
       The self value.
    log self detail:Text -> Progress =
        log_impl self.logger "LOG {}:{}" Log_Level.Finest [self.handle, detail]
        self

    ## Simple name of the progress
    to_text self = "Progress"

## ---
   private: true
   ---
type Log_Level
    ## Finest (Trace) level log message.
    Finest

    ##  Fine (Debug) level log message.
    Fine

    ## Info level log message.
    Info

    ## Warning level log message.
    Warning

    ## Severe level log message.
    Severe

Log_Level.from (that:Text) =
    case that.to_case ..Lower of
        "finest" -> ..Finest
        "trace" -> ..Finest
        "fine" -> ..Fine
        "debug" -> ..Fine
        "info" -> ..Info
        "warning" -> ..Warning
        _ -> ..Severe

## Utility type for profiling

   Should be controlled by an environment variable set to the log level:
   - `ENSO_PROFILE_VIZZES` - for visualizations.
   - `ENSO_PROFILE_SQL` - for SQL queries.
   - `ENSO_PROFILE_TABLE` - for table function calls.
type Profile
    ## ---
       advanced: true
       icon: time
       ---
       Time the evaluation of a function, log the duration and return the result.

       ## Arguments
        - `level`: Log level to log the duration at. If `Nothing`, the duration is not logged.
        - `label`: Label to log with the duration.
        - `function`: Function to execute.
        - `suffix_callback`: Optional callback to generate a suffix for the log message based
           on the result of the function. The callback is only called if `level` is not `Nothing`.
        - `module`: Module to log the message to. Defaults to `Profile`.
    time_execution level:(Log_Level | Nothing) ~label:Text ~function suffix_callback=Nothing module=Profile =
        if Nothing == level then @Tail_Call function else
            pair = Duration.time_execution function

            ## If the function threw an error, we just return the error
            Error.return_if_error pair.second

            duration = pair.first
            suffix = if suffix_callback == Nothing then "" else suffix_callback pair.second
            module.log_message ("Execution time for " + label + ": " + duration.to_text + suffix) level
            pair.second

private log_impl logger ~message level args =
    builder = case level of
        Log_Level.Finest -> logger.atTrace
        Log_Level.Fine -> logger.atDebug
        Log_Level.Info -> logger.atInfo
        Log_Level.Warning -> logger.atWarn
        Log_Level.Severe -> logger.atError

    builder.setMessage message
    args.each a->
        builder.addArgument a

    builder.log

from Standard.Base import all
import Standard.Base.Errors.Illegal_Argument.Illegal_Argument
import Standard.Base.Errors.Illegal_State.Illegal_State
import Standard.Base.Errors.Unimplemented.Unimplemented
import Standard.Base.Logging.Log_Level
import Standard.Base.Logging.Profile
import Standard.Base.Runtime.Context
import Standard.Base.Runtime.Managed_Resource.Managed_Resource
import Standard.Base.Runtime.State
from Standard.Base.Enso_Cloud.Enso_Secret import as_hideable_value

from Standard.Table import Table, Value_Type

import project.Internal.In_Transaction.In_Transaction
import project.Internal.Statement_Setter.Statement_Setter
import project.SQL.SQL_Statement
from project.Errors import SQL_Error, SQL_Timeout

polyglot java import java.sql.Connection
polyglot java import java.sql.DatabaseMetaData
polyglot java import java.sql.PreparedStatement
polyglot java import org.enso.base.enso_cloud.HideableValue
polyglot java import org.enso.base.enso_cloud.HideableValue.Factory
polyglot java import org.enso.base.enso_cloud.HideableValue.KeyValuePair
polyglot java import org.enso.database.dryrun.OperationSynchronizer
polyglot java import org.enso.database.JDBCDriverTypes
polyglot java import org.enso.database.JDBCProxy

type JDBC_Connection
    ## ---
       private: true
       ---
       ## Arguments
        - `connection_resource`: a `Managed_Resource` containing the Java
          Connection instance.
        - `operation_synchronizer`: a helper for synchronizing access to the
          underlying Connection.
        - `sql_error_handler`: a function wrapper to catch SQL errors.
    private Value connection_resource operation_synchronizer sql_error_handler

    ## ---
       private: true
       ---
       Closes the connection releasing the underlying database resources
       immediately instead of waiting for them to be automatically released.
       The connection is not usable afterwards.
    close : Nothing
    close self = _synchronized self <|
        self.connection_resource.finalize

    ## ---
       private: true
       ---
       Open the connection to the database, then run the action wrapping any SQL
       errors.
    with_connection : (Connection -> Any) -> Any
    with_connection self action (related_query:(Nothing|Text)=Nothing) =
        _synchronized self <| self.sql_error_handler related_query=related_query <|
            self.connection_resource.with action

    ## ---
       private: true
       ---
       Runs the provided callback only if no thread is currently inside a
       `synchronized` critical section (including the current thread).
    run_maintenance_action_if_possible : (Nothing -> Any) -> Nothing
    run_maintenance_action_if_possible self callback = Context.Output.with_enabled <|
        self.operation_synchronizer.runMaintenanceActionIfPossible callback

    ## ---
       private: true
       ---
       Open the connection to the database, then run the action passing the
       database's metadata wrapping any SQL errors.
    with_metadata : (DatabaseMetaData -> Any) -> Any
    with_metadata self ~action = self.with_connection connection->
        metadata = connection.getMetaData
        action metadata

    ## ---
       private: true
       ---
       Runs the provided action with a prepared statement, adding contextual
       information to any thrown SQL errors.

       ## Arguments
        - `query`: The query to prepare. It may be either a raw SQL statement or
          a `SQL_Statement`.
        - `statement_setter`: A strategy for filling holes in the prepared
          statement.
        - `action`: The action to run with the prepared statement.
        - `skip_log`: If `True`, the query will not be logged even with logging
          enabled. This is used to avoid logging a query that is not really run
          (e.g. `ensure_query_has_no_holes` which prepares a statement but does
          not execute it).
    with_prepared_statement : Text | SQL_Statement -> Statement_Setter -> (PreparedStatement -> Any) -> Boolean -> Any
    with_prepared_statement self query:(Text | SQL_Statement) statement_setter action skip_log=False = _profile_sql_if_enabled self query.to_text skip_log=skip_log <|
        prepared = if query.is_a Text then [query, []] else query.prepare
        self.with_connection related_query=prepared.first java_connection->
            stmt = java_connection.prepareStatement prepared.first

            handle_any caught_panic =
                stmt.close
                if caught_panic.payload.is_a Illegal_State . not then Panic.throw caught_panic else
                    Error.throw Illegal_Argument.Error caught_panic.payload.message

            result = Panic.catch Any handler=handle_any <|
                _set_statement_values stmt statement_setter prepared.second
            Error.return_if_error result

            Managed_Resource.bracket stmt .close action

    ## ---
       private: true
       ---
       Checks that the query has no holes, and if it does, throws an error.
    ensure_query_has_no_holes : Text -> Nothing ! Illegal_Argument
    ensure_query_has_no_holes self raw_sql:Text = self.with_connection related_query=raw_sql java_connection->
        ## We cannot run this check on every query, because in some
           backends (e.g. Postgres) running `getParameterMetaData`
           seems to trigger logic for figuring out types of the holes.
           In some of our generated queries, the driver is unable to
           figure out the types and fails with an exception.
        stmt = java_connection.prepareStatement raw_sql
        expected_parameter_count = stmt.getParameterMetaData.getParameterCount
        if expected_parameter_count != 0 then
            Error.throw <| Illegal_Argument.Error 'The provided raw SQL query should not contain any holes ("?").'

    ## ---
       private: true
       ---
       Performs the given action within a transaction.
       Once the action is completed, the transaction is committed.
       If a panic or dataflow error escapes from the action, the transaction is
       rolled-back and closed.
       If the rollback fails and panics, the panic related to the rollback will
       take precedence over the original panic that caused that rollback.
    run_within_transaction : Any -> Any
    run_within_transaction self ~action =
        if In_Transaction.is_in_transaction then
            Panic.throw (Illegal_State.Error "`run_within_transaction` is executed within an existing transaction. Nested transactions are not supported.")

        inner_action java_connection =
            handle_panic caught_panic =
                java_connection.rollback
                Panic.throw caught_panic
            result = Panic.catch Any handler=handle_panic <|
                In_Transaction.mark_running_in_transaction action
            case result.is_error of
                True -> java_connection.rollback
                False -> java_connection.commit
            result

        self.with_connection java_connection->
            default_autocommit = java_connection.getAutoCommit
            if default_autocommit.not then inner_action java_connection else
                Managed_Resource.bracket (java_connection.setAutoCommit False) (_ -> java_connection.setAutoCommit default_autocommit) _->
                    inner_action java_connection

    ## ---
       private: true
       ---
       Insert rows from an in-memory table using a prepared query template in
       batches for efficiency.
       It is the caller's responsibility to call this method from within a
       transaction to ensure consistency.
    batch_insert : Text -> Statement_Setter -> Table -> Integer -> Vector Value_Type | Nothing -> Integer | Nothing -> Nothing
    batch_insert self insert_template statement_setter table batch_size expected_type_hints=Nothing row_limit=Nothing =
        In_Transaction.ensure_in_transaction
        _profile_sql_if_enabled self insert_template <| self.with_connection related_query=insert_template java_connection->
            Managed_Resource.bracket (java_connection.prepareStatement insert_template) .close stmt->
                table_row_count = table.row_count
                num_rows = case row_limit of
                    Nothing -> table_row_count
                    limit : Integer -> Math.min table_row_count limit
                columns = table.columns
                check_rows updates_array expected_size =
                    updates = Vector.from_polyglot_array updates_array
                    if updates.length != expected_size then Panic.throw <| Illegal_State.Error "The batch update unexpectedly affected "+updates.length.to_text+" rows instead of "+expected_size.to_text+"." else
                        updates.each affected_rows->
                            if affected_rows != 1 then
                                Panic.throw <| Illegal_State.Error "A single update within the batch unexpectedly affected "+affected_rows.to_text+" rows."
                0.up_to num_rows . each row_id->
                    values = columns.map col-> col.at row_id
                    _set_statement_values stmt statement_setter values expected_type_hints=expected_type_hints
                    stmt.addBatch
                    if (row_id+1) % batch_size == 0 then check_rows stmt.executeBatch batch_size
                if num_rows % batch_size != 0 then check_rows stmt.executeBatch (num_rows % batch_size)

## ---
   private: true
   ---
   A special method used by dialects that construct a Java JDBC connection using
   some custom logic.
create types_record url:Text properties:Vector catalog:Text="" schema:Text="" =
    ## ---
       private: true
       ---
       Creates a handler for SQL Errors.

       ## Arguments
       - `types_record`: The JDBC driver types record containing exception classes.

       ## Returns
       A function which executes `action` and returns its result, catching any
       panics and if they are coming from JDBC, wraps them with our own error
       types and returns as regular data-flow errors.
    create_sql_error_handler types_record =
        handler ~action related_query=Nothing =
            Panic.catch types_record.sqlExceptionClass action caught_panic->
                if caught_panic.is_a types_record.sqlTimeoutExceptionClass then Error.throw (SQL_Timeout.Error caught_panic.payload related_query) else
                    Error.throw (SQL_Error.Error caught_panic.payload related_query)
        handler

    ## ---
       private: true
       ---
       Converts a vector of Enso key-value pairs into Java properties.
    properties_as_java_props properties hideable_value_factory =
        properties.map pair->
            java_value = if hideable_value_factory.is_a pair.second then pair.second else
                as_hideable_value pair.second factory=hideable_value_factory
            hideable_value_factory.createPair pair.first java_value

    sql_error_handler = create_sql_error_handler types_record
    java_props = properties_as_java_props properties types_record.hideableValueFactory
    java_connection = sql_error_handler <| types_record.getConnectionWithCatalogSchema url java_props catalog schema
    resource = Managed_Resource.register java_connection close_connection
    JDBC_Connection.Value resource types_record.newOperationSynchronizer sql_error_handler

## ---
   private: true
   ---
   This cannot be a closure due to limitations of Managed_Resource.

   ## Arguments
    - `connection`: The connection to close.
private close_connection connection:Connection -> Nothing =
    connection.close

## ---
   private: true
   ---
   Uses the provided `Statement_Setter` strategy to fill holes in a provided
   `PreparedStatement`.
   A list of expected value types can be passed as `expected_type_hints` to add
   these hints to the `Statement_Setter` to customize the behaviour for some
   specific target value types.
private _set_statement_values stmt:PreparedStatement statement_setter:Statement_Setter values:Vector (expected_type_hints : (Vector Value_Type | Nothing) = Nothing) -> Nothing =
    values.each_with_index ix-> value->
        type_hint = case expected_type_hints of
            Nothing -> Nothing
            hints : Vector -> hints.at ix
        statement_setter.fill_hole stmt (ix + 1) type_hint value

## ---
   private: true
   ---
   A helper that logs performed SQL queries/statements run-time to a profiling
   file, if an environment variable is set.
private _profile_sql_if_enabled (jdbc_connection : JDBC_Connection) (~query_text : Text) ~action (skip_log:Boolean=False) =
    make_label =
        db_id = jdbc_connection.with_metadata .getDatabaseProductName
        "[" + db_id + "] " + query_text.to_display_text

    result = Profile.time_execution _profile_level label=make_label module=JDBC_Connection <|
        action

    ## If the action returns a dataflow error, `time_execution` returns the error, no duration.
       We could work around this. But we don't want to - the failing queries likely did not run anyway,
       so their time info would most likely be an outlier. For current purposes it makes sense to ignore such cases.
    Error.return_if_error result

    path = if skip_log then "" else Environment.get "ENSO_SQL_LOG_PATH" . if_nothing ""
    if path.is_empty then result else
        # E.g. [Time] [SQLite] SELECT * FROM "test"
        padded_query = make_label.pad 100
        log_line = "[" + Date_Time.now.to_text + "] " + padded_query + '\n'
        Context.Output.with_enabled <|
            log_line.write path on_existing_file=Existing_File_Behavior.Append

        result

## ---
   private: true
   ---
   Runs the provided action ensuring that no other thread is working with
   this Connection concurrently.
private _synchronized (jdbc_connection : JDBC_Connection) ~action =
    jdbc_connection.operation_synchronizer.runSynchronizedAction _->action

private _profile_level = State.get Table if_missing=_profile_level_from_env

private _profile_level_from_env =
    env_val = Environment.get "ENSO_PROFILE_SQL"
    if env_val == Nothing then Nothing else
        level = Log_Level.from env_val
        if level.is_error then Nothing else level

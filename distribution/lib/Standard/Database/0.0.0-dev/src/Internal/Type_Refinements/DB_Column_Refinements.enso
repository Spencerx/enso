private

from Standard.Base import all

import Standard.Table.Refined_Types.Numeric_Column.Numeric_Column
from Standard.Table import Column, Value_Type

import project.DB_Column.DB_Column

refine_column (column : DB_Column) =
    inferred_value_type = (column:Column).inferred_precise_value_type
    case inferred_value_type of
        Value_Type.Integer _ -> (column : Column & DB_Column & Numeric_Column)
        Value_Type.Byte -> (column : Column & DB_Column & Numeric_Column)
        Value_Type.Float _ -> (column : Column & DB_Column & Numeric_Column)
        Value_Type.Decimal _ _ -> (column : Column & DB_Column & Numeric_Column)
        _ -> (column : Column & DB_Column)

private

## Conversions that are used for type refinements.
   They should never be exported or used elsewhere.

from Standard.Base import all
import Standard.Base.Errors.Illegal_Argument.Illegal_Argument

import Standard.Table.Internal.Type_Refinements.Typed_Column_Helpers
import Standard.Table.Refined_Types.Numeric_Column.Numeric_Column
from Standard.Table import Value_Type

import project.DB_Column.DB_Column

## This conversion is internal and should never be exported.
Numeric_Column.from (that : DB_Column) =
    if that.value_type.is_numeric.not then
        Error.throw (Illegal_Argument.Error "Cannot convert a "+that.value_type.to_display_text+" column to a numeric column.")
    Typed_Column_Helpers.make_numeric_column that DB_Numeric_Column_Implementation

type DB_Numeric_Column_Implementation
    abs column =
        Value_Type.expect_numeric column <|
            new_name = column.naming_helper.function_name "abs" [column]
            column.make_unary_op "ABS" new_name

    signum column =
        Value_Type.expect_numeric column <|
            new_name = column.naming_helper.function_name "signum" [column]
            column.make_unary_op "SIGNUM" new_name

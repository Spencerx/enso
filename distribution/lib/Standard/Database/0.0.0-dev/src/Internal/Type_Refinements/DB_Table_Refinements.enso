private

from Standard.Base import all

import Standard.Table.Refined_Types.Numeric_Column.Numeric_Column
from Standard.Table import Column, Value_Type, Table

import project.DB_Column.DB_Column
import project.DB_Table.DB_Table
from project.Internal.Type_Refinements.DB_Table_Conversions import all
from project.Internal.Type_Refinements.Single_Column_DB_Table_Conversions import all
from project.Internal.Type_Refinements.Single_Column_Typed_DB_Table_Conversions import all

refine_table (table : Table & DB_Table) =
    if table . column_count != 1 then (table : Table & DB_Table) else
        _refine_single_column_table table

private _refine_single_column_table table =
    column = (table:Table).at 0
    inferred_value_type = (column:Column).inferred_precise_value_type
    case inferred_value_type of
        Value_Type.Integer _ -> (table : Table & DB_Table & Column & DB_Column & Numeric_Column)
        Value_Type.Byte -> (table : Table & DB_Table & Column & DB_Column & Numeric_Column)
        Value_Type.Float _ -> (table : Table & DB_Table & Column & DB_Column & Numeric_Column)
        Value_Type.Decimal _ _ -> (table : Table & DB_Table & Column & DB_Column & Numeric_Column)
        _ -> (table : Table & DB_Table & Column & DB_Column)

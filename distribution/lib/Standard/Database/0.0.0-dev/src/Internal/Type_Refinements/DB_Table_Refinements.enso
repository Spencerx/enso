private

from Standard.Base import all

import Standard.Table.Refined_Types.Numeric_Column.Numeric_Column
from Standard.Table import Column, Value_Type

import project.DB_Column.DB_Column
import project.DB_Table.DB_Table
from project.Internal.Type_Refinements.Single_Column_DB_Table_Conversions import all
from project.Internal.Type_Refinements.Single_Column_Typed_DB_Table_Conversions import all

refine_table (table : DB_Table) =
    if is_single_column table . not then table else
        _refine_single_column_table table

is_single_column table:DB_Table -> Boolean =
    table.column_count == 1

private _refine_single_column_table table =
    column = table.at 0
    inferred_value_type = (column:Column).inferred_precise_value_type
    case inferred_value_type of
        Value_Type.Integer _ -> (table : DB_Table & Column & DB_Column & Numeric_Column)
        Value_Type.Byte -> (table : DB_Table & Column & DB_Column & Numeric_Column)
        Value_Type.Float _ -> (table : DB_Table & Column & DB_Column & Numeric_Column)
        Value_Type.Decimal _ _ -> (table : DB_Table & Column & DB_Column & Numeric_Column)
        _ -> (table : DB_Table & Column & DB_Column)

type DB_Text_Column_Implementation
    to_case column case_option:Case=..Lower locale:Locale=Locale.default =
        if locale != Locale.default then
            Unimplemented.throw "Locale-specific to_case is not supported by database backends."
        new_name = (naming_helper column).function_name "to_case" [column, case_option.to_text]
        cased_column = case case_option of
            Case.Upper -> DB_Text_Column_Implementation.upper column
            Case.Lower -> DB_Text_Column_Implementation.lower column
            Case.Proper -> DB_Text_Column_Implementation.proper column
            Case.Title -> DB_Text_Column_Implementation.proper column
        cased_column . rename new_name

    length column =
        Value_Type.expect_text column <|
            new_name = (naming_helper column).function_name "length" [column]
            make_unary_op column "LENGTH" new_name

    char_length column =
        Value_Type.expect_text column <|
            new_name = (naming_helper column).function_name "char_length" [column]
            make_unary_op column "LENGTH" new_name

    upper column =
        Value_Type.expect_text column <|
            new_name = (naming_helper column).function_name "upper" [column]
            make_unary_op column "UPPER" new_name

    lower column =
        Value_Type.expect_text column <|
            new_name = (naming_helper column).function_name "lower" [column]
            make_unary_op column "LOWER" new_name

    proper column =
        Value_Type.expect_text column <|
            new_name = (naming_helper column).function_name "proper" [column]
            make_unary_op column "PROPER" new_name

{
  "extends": "./tsconfig.json",
  "include": [
    "env.d.ts",
    "eslint.config.js",
    "integration-test/**/*",
    "playwright.config.*",
    "project-manager-shim-middleware/*.ts",
    "src/dashboard/components/types.ts",
    "src/dashboard/hooks/storeHooks.ts",
    "src/dashboard/modules/payments/constants.ts",
    "src/dashboard/services/Backend.ts",
    "src/dashboard/services/ProjectManager/types.ts",
    "src/dashboard/services/RemoteBackend.ts",
    "src/dashboard/services/RemoteBackend/ids.ts",
    "src/dashboard/services/remoteBackendPaths.ts",
    "src/dashboard/utilities/async.ts",
    "src/dashboard/utilities/download.ts",
    "src/dashboard/utilities/equalities.ts",
    "src/dashboard/utilities/event.ts",
    "src/dashboard/utilities/inputBindings.ts",
    "src/dashboard/utilities/newtype.ts",
    "src/dashboard/utilities/object.ts",
    "src/dashboard/utilities/path.ts",
    "src/dashboard/utilities/permissions.ts",
    "src/dashboard/utilities/string.ts",
    "src/dashboard/utilities/write.ts",
    "src/dashboard/utilities/zustand.ts",
    "src/project-view/components/GraphEditor/widgets/WidgetFunction/consts.ts",
    "src/project-view/util/assert.ts",
    "src/project-view/util/ast/abstract.ts",
    "src/project-view/util/ast/index.ts",
    "src/project-view/util/ast/match.ts",
    "src/project-view/util/data/result.ts",
    "src/project-view/util/equals.ts",
    "src/project-view/util/iconMetadata/iconName.ts",
    "src/project-view/util/projectPath.ts",
    "src/project-view/util/qualifiedName.ts",
    "src/project-view/util/shortcuts.ts",
    "src/providers/featureFlags.ts",
    "src/providers/session/constants.ts",
    "src/utils/zustand.ts",
    "tailwind.config.ts",
    "vite.config.*",
    "vite.test.config.*",
    "vitest.config.*"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "verbatimModuleSyntax": true,
    "types": ["node", "vitest/importMeta"],
    "paths": {
      "@/*": ["./src/project-view/*"],
      "#/*": ["./src/dashboard/*"],
      "$/*": ["./src/*"],
      "integration-test/*": ["./integration-test/*"]
    }
  }
}
